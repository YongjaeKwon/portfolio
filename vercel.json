{
  "redirects": [
    {
      "source": "/resume-product.pdf",
      "destination": "/resume.pdf",
      "permanent": false
    },
    {
      "source": "/resume-api-data.pdf",
      "destination": "/resume.pdf",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive, nosnippet, noimageindex"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
